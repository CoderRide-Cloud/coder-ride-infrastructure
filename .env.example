# ==========================================
# CoderRide Backend Environment Variables
# ==========================================

# Database
POSTGRES_USER=coderride
POSTGRES_PASSWORD=password
POSTGRES_DB=coderride_master

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_256_bits_long
JWT_EXPIRATION_MS=86400000

# GitHub OAuth App Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
NOTIFICATION_EMAIL=notifications@coderride.com
ADMIN_EMAIL=admin@coderride.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Discord Webhooks
DISCORD_WEBHOOK_NEW_USERS=
DISCORD_WEBHOOK_APPROVALS=
DISCORD_WEBHOOK_REJECTIONS=
DISCORD_WEBHOOK_NEW_PROJECTS=
DISCORD_WEBHOOK_PROJECT_APPROVALS=
DISCORD_WEBHOOK_PROJECT_REJECTIONS=

# Infrastructure
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://localhost:8761/eureka/
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
ZIPKIN_URL=http://localhost:9411/api/v2/spans
