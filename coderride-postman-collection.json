{
  "info": {
    "name": "CoderRide Developer Community API",
    "description": "Comprehensive API Tests for all endpoints including edge cases (60+ cases). Covers CRUD operations, permission boundaries, and input validation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0 - Setup (run first)",
      "item": [
        {
          "name": "Login via GitHub (saves token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"githubId\": \"12345678\",\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"avatarUrl\": \"https://avatars.githubusercontent.com/u/1\",\n  \"githubUrl\": \"https://github.com/testuser\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/github", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "github"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login returns 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  let t = json.token.trim();",
                  "  if (t.startsWith('Bearer ')) { t = t.substring(7); }",
                  "  pm.collectionVariables.set('token', t);",
                  "  console.log('Token saved to {{token}}');",
                  "} else {",
                  "  console.error('No token in response — check auth-service is running');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify token works (GET /auth/me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/me", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "me"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Token is valid (200)', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 401) {",
                  "  const body = pm.response.json();",
                  "  console.error('Gateway rejected token:', body.message);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
